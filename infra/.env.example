# ChimeMe Environment Variables — Template
# 실제 사용 시 .env.development / .env.production로 복사 후 값 채우기
# ⚠️ 절대 git에 커밋 금지 (.gitignore에 .env / .env.* 포함됨)

# === Firebase (dev 또는 prod에 따라 다른 프로젝트 사용) ===
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# === App Check (디버그용 — 프로덕션에서는 SDK 자동 처리) ===
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# === 앱 식별 ===
EXPO_PUBLIC_APP_ENV=development # development | preview | production
EXPO_PUBLIC_APP_URL=https://chimeme.app

# === Sentry (선택, P2) ===
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# === EAS Secrets (eas.json에서 참조, .env에 적지 않음) ===
# EAS Secrets로 등록 후 eas.json에서 ${EXPO_PUBLIC_FIREBASE_API_KEY} 식으로 주입
# 등록 명령:
#   eas secret:create --scope project --name FIREBASE_API_KEY_DEV --value "<value>"
