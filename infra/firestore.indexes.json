{
  "indexes": [
    {
      "_comment": "main 그룹 리스트 조회 — memberIds array-contains + 필요 시 createdAt 정렬",
      "collectionGroup": "groups",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "memberIds", "arrayConfig": "CONTAINS" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "groups/{gid}/posts — 슬롯별 영상 조회",
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "hourSlotDate", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "groups/{gid}/posts — 멤버별 최신 영상",
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "authorId", "order": "ASCENDING" },
        { "fieldPath": "hourSlotDate", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "memberships — uid로 내 그룹 목록 조회",
      "collectionGroup": "memberships",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "uid", "order": "ASCENDING" },
        { "fieldPath": "joinedAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "memberships — groupId로 그룹 멤버 조회 (FCM 발송용)",
      "collectionGroup": "memberships",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "groupId", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "groups - ownerId로 본인 소유 그룹 조회 (계정 삭제 시)",
      "collectionGroup": "groups",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "ownerId", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "invites - 활성 초대 링크 조회",
      "collectionGroup": "invites",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "groupId", "order": "ASCENDING" },
        { "fieldPath": "expiresAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "blocks - 본인 차단 목록 (시간순)",
      "collectionGroup": "blocks",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "blockerId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "reports - 동일 타깃 신고 카운트 (자동 가림 트리거)",
      "collectionGroup": "reports",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "targetId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "reports - 신고자 본인 이력 + 24h 카운트",
      "collectionGroup": "reports",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "reporterId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    },
    {
      "_comment": "reports - 관리자 검토 큐 (오래된 순)",
      "collectionGroup": "reports",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "ASCENDING" }
      ]
    },
    {
      "_comment": "groups/{gid}/messages - 본인 메시지 (탈퇴 시 익명화용)",
      "collectionGroup": "messages",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "authorId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ]
    }
  ],
  "fieldOverrides": []
}
