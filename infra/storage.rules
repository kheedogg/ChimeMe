// ChimeMe Cloud Storage Security Rules
// 배포: firebase deploy --only storage:rules

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // === 영상: groups/{gid}/{slotKey}/{uid}.mp4 ===
    // D-12-07 멱등 경로, D-12-13 landscape, D-12-03 2MB 한도
    match /groups/{gid}/{slotKey}/{filename} {
      // 읽기: 그룹 멤버만
      allow read: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(gid)).data.memberIds;

      // 쓰기: 본인 파일만 + 크기/타입 제한
      allow write: if request.auth != null
        && filename == request.auth.uid + '.mp4'
        && request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(gid)).data.memberIds
        && request.resource.size < 2 * 1024 * 1024 // 2 MB 한도
        && request.resource.contentType == 'video/mp4';

      // 삭제: 본인만 (Cloud Function 정리 시는 Admin SDK 사용)
      allow delete: if request.auth != null
        && filename == request.auth.uid + '.mp4';
    }

    // === 썸네일: thumbs/{gid}/{slotKey}/{uid}_360.webp ===
    match /thumbs/{gid}/{slotKey}/{filename} {
      allow read: if request.auth != null
        && request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(gid)).data.memberIds;
      allow write: if false; // Cloud Function이 생성만
    }

    // === 프로필 사진: profiles/{uid}.jpg ===
    match /profiles/{filename} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && filename == request.auth.uid + '.jpg'
        && request.resource.size < 1 * 1024 * 1024 // 1 MB
        && request.resource.contentType.matches('image/.*');

      allow delete: if request.auth != null
        && filename == request.auth.uid + '.jpg';
    }

    // === 기본 차단 ===
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
